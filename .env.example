# --- Supabase Configuration ---
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI & LLM Configuration ---
# Gemini API Key (Required for AI features)
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-key
# Fallback for some backend services
GOOGLE_API_KEY=your-gemini-key

# --- OmniHermes & Computing Fabric ---
# URL for the Hermes Gateway (Local or Remote)
NEXT_PUBLIC_HERMES_GATEWAY_URL=http://127.0.0.1:8642
NEXT_PUBLIC_HERMES_API_URL=http://127.0.0.1:8642

# BlueCC Hybrid Compute (Optional)
BLUE_CC_API_KEY=your-bluecc-key
BLUE_CC_TOKEN=your-bluecc-token

# E2B Sandbox (Optional, for Code Execution)
E2B_API_KEY=your-e2b-key

# --- Site Configuration ---
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

{
  "hosting": {
    "site": "esggo-original",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "emulators": {
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    }
  },
  "dataconnect": {
    "source": "dataconnect"
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "ESG GO",
        "supportEmail": "dingjunhong1028@gmail.com"
      }
    }
  },
  "functions": {
    "source": ".",
    "runtime": "nodejs20",
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/.next/**",
      "**/build/**"
    ],
    "predeploy": [
      "npm install --prefix dataconnect",
      "npm run build"
    ]
  }
}
